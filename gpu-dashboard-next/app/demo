"use client";

import React, { useState, useEffect, useMemo } from "react";
import Image from "next/image";
import { 
  Zap, Search, RotateCcw, ChevronLeft, ChevronRight, Star, 
  Check, Calculator, BarChart3, X, ExternalLink 
} from "lucide-react";

// --- CHART.JS IMPORTS ---
import {
  Chart as ChartJS,
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  BarElement,
  ArcElement,
  Title,
  Tooltip,
  Legend,
  Filler
} from 'chart.js';
import { Line, Scatter, Bar, Pie } from 'react-chartjs-2';

ChartJS.register(
  CategoryScale, LinearScale, PointElement, LineElement, 
  BarElement, ArcElement, Title, Tooltip, Legend, Filler
);

// --- INTERFACES ---
interface GPUData {
  provider: string;
  product: string;
  gpu_count: number;
  vram_gb: number;
  vcpus: number;
  system_ram_gb: number;
  local_storage_tb: number | null;
  price_per_hour_usd: number;
  raw_price: string;
}

interface HistoryPoint {
  date: string;
  price: number;
}

export default function GPUPriceMonitor() {
  // Data & Loading
  const [prices, setPrices] = useState<GPUData[]>([]);
  const [historyData, setHistoryData] = useState<HistoryPoint[]>([]);
  const [loading, setLoading] = useState(true);
  
  // Modals Toggle State
  const [isCalcOpen, setIsCalcOpen] = useState(false);
  const [isAnalyticsOpen, setIsAnalyticsOpen] = useState(false);
  const [selectedGPU, setSelectedGPU] = useState<GPUData | null>(null);

  // Filter State
  const [search, setSearch] = useState("");
  const [providerFilter, setProviderFilter] = useState("all");
  const [gpuType, setGpuType] = useState("all");
  const [vramRange, setVramRange] = useState<[number, number]>([0, 200]);
  const [priceRange, setPriceRange] = useState<[number, number]>([0, 100]);
  const [priceOrder, setPriceOrder] = useState("asc");
  const [bestValue, setBestValue] = useState(false);
  const [topDeals, setTopDeals] = useState(false);

  // Pagination
  const [currentPage, setCurrentPage] = useState(1);
  const ROWS_PER_PAGE = 12;

  // Internal Logic States
  const [compareList, setCompareList] = useState<GPUData[]>([]);
  const [modalTab, setModalTab] = useState<"specs" | "trends">("specs");
  const [analyticsTab, setAnalyticsTab] = useState<"scatter" | "distribution" | "histogram">("scatter");
  const [hoursPerDay, setHoursPerDay] = useState(8);
  const [daysPerMonth, setDaysPerMonth] = useState(22);

  const normalize = (value?: string) => value ? value.toUpperCase().trim() : "";

  const providerLogos: Record<string, string> = {
    AZURE: "/providers/azure.png",
    COREWEAVE: "/providers/coreweave.png",
    CRUSOE: "/providers/crusoe.png",
    DENVR: "/providers/denvr.png",
    GCP: "/providers/gcp.png",
    LAMBDA: "/providers/lambda.png",
    NEBIUS: "/providers/nebius.png",
    RUNPOD: "/providers/runpod.png",
  };

  const providerColors: Record<string, string> = {
    coreweave: '#8b5cf6', denvr: '#f59e0b', crusoe: '#10b981', 
    lambda: '#3b82f6', runpod: '#ec4899', azure: '#0ea5e9', 
    gcp: '#ef4444', nebius: '#84cc16',
  };

  // --- DATA FETCHING ---
  useEffect(() => {
    const fetchPrices = async () => {
      try {
        const mergedMap = new Map<string, GPUData>();
        for (let i = 0; i < 7; i++) {
          const d = new Date();
          d.setDate(d.getDate() - i);
          const date = d.toISOString().split("T")[0];
          const res = await fetch(`https://freellm.org/history/${date}/all.json`);
          if (res.ok) {
            const data = await res.json();
            data.forEach((item: any) => {
              const key = `${item.provider}-${item.product}`;
              if (item.price_per_hour_usd > 0 && !mergedMap.has(key)) {
                mergedMap.set(key, { ...item, price_per_hour_usd: Number(item.price_per_hour_usd) });
              }
            });
          }
        }
        setPrices(Array.from(mergedMap.values()));
      } catch (err) { console.error(err); } finally { setLoading(false); }
    };
    fetchPrices();
  }, []);

  // --- MEMOIZED DATA ---
  const filtered = useMemo(() => {
    let result = prices.filter(p => {
      const matchSearch = `${p.product} ${p.provider}`.toLowerCase().includes(search.toLowerCase());
      const matchProvider = providerFilter === "all" || normalize(p.provider) === providerFilter;
      const matchType = gpuType === "all" || p.product.toUpperCase().includes(gpuType);
      const matchVram = p.vram_gb >= vramRange[0] && p.vram_gb <= vramRange[1];
      const matchPrice = p.price_per_hour_usd >= priceRange[0] && p.price_per_hour_usd <= priceRange[1];
      return matchSearch && matchProvider && matchType && matchVram && matchPrice;
    });

    result.sort((a, b) => {
      if (bestValue) return (a.price_per_hour_usd / a.vram_gb) - (b.price_per_hour_usd / b.vram_gb);
      return priceOrder === "asc" ? a.price_per_hour_usd - b.price_per_hour_usd : b.price_per_hour_usd - a.price_per_hour_usd;
    });

    return topDeals ? result.slice(0, 10) : result;
  }, [prices, search, providerFilter, gpuType, vramRange, priceRange, priceOrder, bestValue, topDeals]);

  const limits = useMemo(() => ({
    maxVRAM: Math.max(...prices.map(p => p.vram_gb), 200),
    maxPrice: Math.max(...prices.map(p => p.price_per_hour_usd), 100),
  }), [prices]);

  const paginatedData = filtered.slice((currentPage - 1) * ROWS_PER_PAGE, currentPage * ROWS_PER_PAGE);

  // --- CHART CONFIGS ---
  const scatterData = {
    datasets: Array.from(new Set(filtered.map(d => d.provider))).map(p => ({
      label: p.toUpperCase(),
      data: filtered.filter(d => d.provider === p).map(d => ({ x: d.vram_gb, y: d.price_per_hour_usd, gpuName: d.product })),
      backgroundColor: providerColors[p.toLowerCase()] || '#888',
    }))
  };

  const pieData = {
    labels: Array.from(new Set(filtered.map(p => p.provider.toUpperCase()))),
    datasets: [{
      data: Array.from(new Set(filtered.map(p => p.provider))).map(prov => filtered.filter(f => f.provider === prov).length),
      backgroundColor: Array.from(new Set(filtered.map(p => p.provider))).map(l => providerColors[l.toLowerCase()] || '#888'),
      borderWidth: 0
    }]
  };

  // --- SHARED UI COMPONENTS ---
  const ModalWrapper = ({ isOpen, onClose, title, children, icon: Icon }: any) => {
    if (!isOpen) return null;
    return (
      <div className="fixed inset-0 bg-black/90 backdrop-blur-md z-[200] flex items-center justify-center p-4">
        <div className="bg-[#0a0a0a] border border-gray-800 w-full max-w-4xl max-h-[90vh] overflow-y-auto rounded-3xl shadow-2xl relative">
          <div className="sticky top-0 bg-[#0a0a0a]/80 backdrop-blur-md px-8 py-6 border-b border-gray-800 flex justify-between items-center z-10">
            <div className="flex items-center gap-3">
              <div className="p-2 bg-blue-500/10 rounded-lg"><Icon className="w-5 h-5 text-blue-500" /></div>
              <h2 className="text-xl font-bold tracking-tight text-white">{title}</h2>
            </div>
            <button onClick={onClose} className="p-2 hover:bg-white/5 rounded-full transition text-gray-400 hover:text-white">
              <X className="w-6 h-6" />
            </button>
          </div>
          <div className="p-8">{children}</div>
        </div>
      </div>
    );
  };

  if (loading) return <div className="min-h-screen bg-black flex items-center justify-center text-gray-500 animate-pulse font-mono tracking-tighter">INITIALIZING ENGINE...</div>;

  return (
    <main className="min-h-screen bg-black text-white font-sans selection:bg-blue-500/30">
      
      {/* HEADER */}
      <nav className="sticky top-0 z-[100] bg-black/80 backdrop-blur-xl border-b border-gray-900">
        <div className="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
          <div className="flex items-center gap-2">
            <Zap className="w-6 h-6 text-blue-500" fill="currentColor" />
            <span className="text-xl font-black tracking-tighter uppercase">CloudDealHunt</span>
          </div>
          <div className="flex gap-4">
            <button 
              onClick={() => setIsCalcOpen(true)}
              className="flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 border border-gray-800 rounded-xl text-xs font-bold transition-all"
            >
              <Calculator className="w-4 h-4 text-blue-500" /> CALCULATOR
            </button>
            <button 
              onClick={() => setIsAnalyticsOpen(true)}
              className="flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-xl text-xs font-bold transition-all"
            >
              <BarChart3 className="w-4 h-4" /> MARKET ANALYTICS
            </button>
          </div>
        </div>
      </nav>

      <div className="max-w-7xl mx-auto p-6 space-y-8">
        {/* HERO */}
        <div className="py-12 text-center space-y-4">
          <h1 className="text-6xl md:text-8xl font-black tracking-tighter bg-gradient-to-b from-white to-gray-600 bg-clip-text text-transparent">
            UPTIME IS MONEY.
          </h1>
          <p className="text-gray-500 font-medium tracking-tight max-w-xl mx-auto text-sm md:text-base">
            Live index of the global GPU cloud market. Compare compute density against hourly burn rates in real-time.
          </p>
        </div>

        {/* FILTER CONTROL BAR */}
        <div className="bg-[#0a0a0a] border border-gray-800 rounded-2xl p-2 flex flex-wrap items-center gap-2">
           <div className="flex-1 min-w-[200px] relative group">
             <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600 group-focus-within:text-blue-500 transition" />
             <input 
               placeholder="Search cluster or chip model..." 
               className="w-full bg-transparent py-3 pl-12 pr-4 text-sm outline-none font-medium"
               value={search} onChange={e => setSearch(e.target.value)}
             />
           </div>
           <select 
             className="bg-black border border-gray-800 rounded-xl px-4 py-2.5 text-[11px] font-bold tracking-widest uppercase outline-none"
             value={providerFilter} onChange={e => setProviderFilter(e.target.value)}
           >
             <option value="all">ALL PROVIDERS</option>
             {Array.from(new Set(prices.map(p => normalize(p.provider)))).map(p => <option key={p} value={p}>{p}</option>)}
           </select>
           <button onClick={() => {setSearch(""); setProviderFilter("all");}} className="p-3 hover:bg-red-500/10 text-gray-600 hover:text-red-500 rounded-xl transition">
             <RotateCcw className="w-4 h-4" />
           </button>
        </div>

        {/* DATA TABLE */}
        <div className="border border-gray-900 rounded-3xl overflow-hidden bg-[#050505]">
          <table className="w-full text-left border-collapse">
            <thead className="bg-[#0a0a0a] border-b border-gray-900">
              <tr className="text-[10px] font-black tracking-[0.2em] text-gray-500 uppercase">
                <th className="px-6 py-5">GPU COMPUTE UNIT</th>
                <th className="px-6 py-5">PROVIDER</th>
                <th className="px-6 py-5 text-center">VRAM</th>
                <th className="px-6 py-5 text-center">CORES</th>
                <th className="px-6 py-5 text-right">HOURLY RATE</th>
                <th className="px-6 py-5 text-center">EST</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-900">
              {paginatedData.map((item, i) => (
                <tr 
                  key={i} 
                  onClick={() => { setSelectedGPU(item); setModalTab("specs"); }}
                  className="group hover:bg-blue-600/[0.03] transition-colors cursor-pointer"
                >
                  <td className="px-6 py-5 font-bold text-sm tracking-tight group-hover:text-blue-400 transition-colors">{item.product}</td>
                  <td className="px-6 py-5">
                    <span className="inline-flex items-center gap-2 text-[11px] font-black uppercase text-gray-400 tracking-wider">
                      <div className="w-1.5 h-1.5 rounded-full" style={{ backgroundColor: providerColors[item.provider.toLowerCase()] }} />
                      {item.provider}
                    </span>
                  </td>
                  <td className="px-6 py-5 text-center font-mono text-xs text-gray-300">{item.vram_gb}GB</td>
                  <td className="px-6 py-5 text-center font-mono text-xs text-gray-500">{item.vcpus}</td>
                  <td className="px-6 py-5 text-right">
                    <span className="px-3 py-1 bg-white/5 rounded-lg font-mono font-bold text-white text-xs border border-white/5">
                      ${item.price_per_hour_usd.toFixed(3)}
                    </span>
                  </td>
                  <td className="px-6 py-5 text-center">
                    <button 
                      onClick={(e) => {
                        e.stopPropagation();
                        if (compareList.some(c => c.product === item.product)) {
                          setCompareList(prev => prev.filter(p => p.product !== item.product));
                        } else {
                          setCompareList(prev => [...prev.slice(-2), item]);
                        }
                      }}
                      className={`p-2 rounded-lg transition-all ${compareList.some(c => c.product === item.product) ? 'bg-blue-600 text-white' : 'bg-gray-900 text-gray-600 hover:text-white'}`}
                    >
                      <Calculator className="w-4 h-4" />
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* --- POPUP: CALCULATOR --- */}
      <ModalWrapper 
        isOpen={isCalcOpen} 
        onClose={() => setIsCalcOpen(false)} 
        title="Monthly Burn Estimator" 
        icon={Calculator}
      >
        <div className="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div className="space-y-8">
            <div className="space-y-4">
              <label className="text-[10px] font-black uppercase tracking-[0.2em] text-blue-500">Usage Density (Hours/Day)</label>
              <input type="range" min="1" max="24" value={hoursPerDay} onChange={e => setHoursPerDay(+e.target.value)} className="w-full h-1 bg-gray-800 rounded-lg appearance-none accent-blue-500" />
              <div className="flex justify-between font-mono text-xl font-bold"><span>{hoursPerDay}h</span> <span className="text-gray-600 text-sm">per day</span></div>
            </div>
            <div className="space-y-4">
              <label className="text-[10px] font-black uppercase tracking-[0.2em] text-blue-500">Billing Cycle (Days/Month)</label>
              <input type="range" min="1" max="31" value={daysPerMonth} onChange={e => setDaysPerMonth(+e.target.value)} className="w-full h-1 bg-gray-800 rounded-lg appearance-none accent-blue-500" />
              <div className="flex justify-between font-mono text-xl font-bold"><span>{daysPerMonth}d</span> <span className="text-gray-600 text-sm">per month</span></div>
            </div>
          </div>
          
          <div className="bg-[#050505] border border-gray-800 rounded-3xl p-6 space-y-4">
            <h3 className="text-xs font-bold text-gray-500 uppercase tracking-widest">Active Comparison</h3>
            {compareList.length > 0 ? compareList.map((gpu, idx) => (
              <div key={idx} className="p-4 bg-white/5 rounded-2xl border border-white/5 flex justify-between items-center group">
                <div>
                  <p className="text-[10px] font-black text-blue-500 uppercase">{gpu.provider}</p>
                  <p className="text-sm font-bold">{gpu.product}</p>
                </div>
                <div className="text-right">
                  <p className="text-xl font-black text-green-400 font-mono">${(gpu.price_per_hour_usd * hoursPerDay * daysPerMonth).toFixed(2)}</p>
                  <p className="text-[10px] text-gray-500 uppercase font-bold">Total / Month</p>
                </div>
              </div>
            )) : <p className="text-gray-600 italic text-sm text-center py-12">No GPUs selected. Tap the calculator icon in the table to add one.</p>}
          </div>
        </div>
      </ModalWrapper>

      {/* --- POPUP: ANALYTICS --- */}
      <ModalWrapper 
        isOpen={isAnalyticsOpen} 
        onClose={() => setIsAnalyticsOpen(false)} 
        title="Market Analytics Engine" 
        icon={BarChart3}
      >
        <div className="space-y-8">
          <div className="flex bg-[#111] p-1 rounded-2xl border border-gray-800 w-fit">
            {(['scatter', 'distribution', 'histogram'] as const).map(tab => (
              <button 
                key={tab}
                onClick={() => setAnalyticsTab(tab)}
                className={`px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${analyticsTab === tab ? 'bg-white text-black' : 'text-gray-500 hover:text-white'}`}
              >
                {tab}
              </button>
            ))}
          </div>
          <div className="h-[400px] w-full relative bg-[#050505] p-8 rounded-3xl border border-gray-900">
            {analyticsTab === 'scatter' && <Scatter data={scatterData} options={{ responsive: true, maintainAspectRatio: false, scales: { x: { grid: { color: '#111' } }, y: { grid: { color: '#111' } } } }} />}
            {analyticsTab === 'distribution' && <div className="h-full flex justify-center"><Pie data={pieData} options={{ maintainAspectRatio: false }} /></div>}
            {analyticsTab === 'histogram' && <div className="flex items-center justify-center h-full text-gray-600 italic">Price volatility histogram processing...</div>}
          </div>
        </div>
      </ModalWrapper>

      {/* --- POPUP: GPU DETAIL --- */}
      <ModalWrapper
        isOpen={!!selectedGPU}
        onClose={() => setSelectedGPU(null)}
        title={selectedGPU?.product || "GPU Details"}
        icon={Star}
      >
        <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div className="space-y-4">
            <div className="p-6 bg-white/5 rounded-2xl border border-white/5 space-y-2">
              <p className="text-[10px] font-black text-blue-500 uppercase tracking-widest">Specifications</p>
              <div className="grid grid-cols-2 gap-4">
                <div><p className="text-xs text-gray-500">VRAM</p><p className="font-bold">{selectedGPU?.vram_gb} GB</p></div>
                <div><p className="text-xs text-gray-500">vCPUs</p><p className="font-bold">{selectedGPU?.vcpus}</p></div>
                <div><p className="text-xs text-gray-500">System RAM</p><p className="font-bold">{selectedGPU?.system_ram_gb} GB</p></div>
                <div><p className="text-xs text-gray-500">Storage</p><p className="font-bold">{selectedGPU?.local_storage_tb || 'N/A'} TB</p></div>
              </div>
            </div>
            <div className="p-6 bg-green-500/10 rounded-2xl border border-green-500/20">
              <p className="text-[10px] font-black text-green-500 uppercase tracking-widest">Active Rate</p>
              <p className="text-4xl font-black font-mono">${selectedGPU?.price_per_hour_usd.toFixed(3)}<span className="text-sm text-green-500/50">/hr</span></p>
            </div>
          </div>
          <div className="bg-[#050505] border border-gray-800 rounded-3xl p-6 flex items-center justify-center">
             <div className="text-center space-y-4">
                <div className="w-16 h-16 bg-blue-500/10 rounded-full flex items-center justify-center mx-auto">
                   <ExternalLink className="w-6 h-6 text-blue-500" />
                </div>
                <p className="text-sm font-bold text-gray-400">Instance provided by <span className="text-white">{selectedGPU?.provider}</span></p>
                <button className="w-full py-4 bg-white text-black font-black text-xs tracking-widest uppercase rounded-2xl hover:bg-gray-200 transition">DEPLOY ON {selectedGPU?.provider}</button>
             </div>
          </div>
        </div>
      </ModalWrapper>
    </main>
  );
}